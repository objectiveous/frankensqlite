+    fn compile_prepared_direct_insert_record_template_numeric_term(
+        expr: &PreparedDirectSimpleInsertExpr,
+    ) -> Option<PreparedDirectInsertRecordTemplateNumericTerm> {
+        match expr {
+            PreparedDirectSimpleInsertExpr::Placeholder(one_based) => Some(
+                PreparedDirectInsertRecordTemplateNumericTerm::Placeholder(*one_based),
+            ),
+            PreparedDirectSimpleInsertExpr::Literal(value) => {
+                Some(PreparedDirectInsertRecordTemplateNumericTerm::Literal(
