+    fn try_build_prepared_direct_insert_record_template(
+        columns: &[ColumnInfo],
+        rowid_alias_col_idx: Option<usize>,
+        compiled_row_values: Option<&[PreparedDirectSimpleInsertExpr]>,
+    ) -> Option<PreparedDirectInsertRecordTemplate> {
+        let exprs = compiled_row_values?;
+        if exprs.len() != columns.len() || columns.iter().any(|column| column.strict_type.is_some())
+        {
+            return None;
+        }
+
+        let template_columns = columns
+            .iter()
+            .zip(exprs.iter())
+            .enumerate()
+            .map(|(col_idx, (column, expr))| {
+                Some(PreparedDirectInsertRecordTemplateColumn {
+                    name: column.name.clone(),
+                    is_rowid_alias: column.is_ipk || rowid_alias_col_idx == Some(col_idx),
+                    notnull: column.notnull,
+                    affinity: Self::type_affinity_for_direct_insert(column.affinity),
+                    op: Self::compile_prepared_direct_insert_record_template_op(expr)?,
+                })
+            })
+            .collect::<Option<Vec<_>>>()?;
+
+        Some(PreparedDirectInsertRecordTemplate {
+            columns: template_columns,
+        })
+    }
