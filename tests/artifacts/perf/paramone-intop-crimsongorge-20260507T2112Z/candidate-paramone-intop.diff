+                BinaryOp::Add | BinaryOp::Subtract | BinaryOp::Multiply | BinaryOp::Divide
+            ) =>
+            {
+                Some(PreparedDirectSimpleInsertExpr::ParamOneFloatBinary {
+                    op,
+                    rhs: *rhs,
+                })
+            }
+            _ => None,
+        }
