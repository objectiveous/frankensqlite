+    fn compile_prepared_direct_insert_record_template_op(
+        expr: &PreparedDirectSimpleInsertExpr,
+    ) -> Option<PreparedDirectInsertRecordTemplateOp> {
+        match expr {
+            PreparedDirectSimpleInsertExpr::Literal(value) => {
+                Some(PreparedDirectInsertRecordTemplateOp::Literal(value.clone()))
+            }
+            PreparedDirectSimpleInsertExpr::Placeholder(one_based) => Some(
+                PreparedDirectInsertRecordTemplateOp::Placeholder(*one_based),
+            ),
+            PreparedDirectSimpleInsertExpr::BinaryOp { left, op, right } => {
+                Some(PreparedDirectInsertRecordTemplateOp::NumericBinary(
+                    Self::compile_prepared_direct_insert_record_template_numeric_binary(
+                        left, *op, right,
+                    )?,
+                ))
+            }
+            PreparedDirectSimpleInsertExpr::ConcatChain(segments) => {
+                Some(PreparedDirectInsertRecordTemplateOp::Concat(
+                    segments
+                        .iter()
+                        .map(Self::compile_prepared_direct_insert_record_template_concat_segment)
+                        .collect::<Option<Vec<_>>>()?,
+                ))
+            }
+            PreparedDirectSimpleInsertExpr::Collate(inner) => {
+                Self::compile_prepared_direct_insert_record_template_op(inner)
+            }
+            PreparedDirectSimpleInsertExpr::UnaryOp { .. }
+            | PreparedDirectSimpleInsertExpr::Cast { .. }
+            | PreparedDirectSimpleInsertExpr::IsNull { .. } => None,
+        }
+    }
+
+    fn compile_prepared_direct_insert_record_template_concat_segment(
+        segment: &PreparedDirectSimpleConcatSegment,
+    ) -> Option<PreparedDirectInsertRecordTemplateConcatSegment> {
+        match segment {
+            PreparedDirectSimpleConcatSegment::NullLiteral => {
+                Some(PreparedDirectInsertRecordTemplateConcatSegment::NullLiteral)
+            }
+            PreparedDirectSimpleConcatSegment::TextLiteral(value) => {
+                Some(PreparedDirectInsertRecordTemplateConcatSegment::TextLiteral(value.clone()))
+            }
+            PreparedDirectSimpleConcatSegment::Literal(value) => Some(
+                PreparedDirectInsertRecordTemplateConcatSegment::Literal(value.clone()),
+            ),
+            PreparedDirectSimpleConcatSegment::Placeholder(one_based) => {
+                Some(PreparedDirectInsertRecordTemplateConcatSegment::Placeholder(*one_based))
+            }
+            PreparedDirectSimpleConcatSegment::Expr(expr) => Some(
+                PreparedDirectInsertRecordTemplateConcatSegment::NumericBinary(
+                    Self::compile_prepared_direct_insert_record_template_numeric_binary_expr(expr)?,
+                ),
+            ),
+        }
+    }
+
+    fn compile_prepared_direct_insert_record_template_numeric_binary_expr(
+        expr: &PreparedDirectSimpleInsertExpr,
+    ) -> Option<PreparedDirectInsertRecordTemplateNumericBinary> {
+        let PreparedDirectSimpleInsertExpr::BinaryOp { left, op, right } = expr else {
+            return None;
+        };
+        Self::compile_prepared_direct_insert_record_template_numeric_binary(left, *op, right)
+    }
+
+    fn compile_prepared_direct_insert_record_template_numeric_binary(
+        left: &PreparedDirectSimpleInsertExpr,
+        op: BinaryOp,
+        right: &PreparedDirectSimpleInsertExpr,
+    ) -> Option<PreparedDirectInsertRecordTemplateNumericBinary> {
+        Some(PreparedDirectInsertRecordTemplateNumericBinary {
+            left: Self::compile_prepared_direct_insert_record_template_numeric_term(left)?,
+            op,
+            right: Self::compile_prepared_direct_insert_record_template_numeric_term(right)?,
+        })
+    }
