+    #[test]
+    fn test_large_prepared_append_publishes_visibility_snapshot() {
+        init_wal_publication_test_tracing();
+        let cx = test_cx();
+        let vfs = MemoryVfs::new();
+        let mut adapter = make_adapter(&vfs, &cx);
+
+        let pages = (0..DIRECT_PREPARED_PUBLICATION_FRAME_THRESHOLD)
+            .map(|index| {
+                let seed = u8::try_from(index % 251).expect("seed fits in u8");
+                sample_page(seed)
+            })
+            .collect::<Vec<_>>();
+        let last_page_index = pages.len() - 1;
+        let frames = pages
+            .iter()
+            .enumerate()
+            .map(|(index, page)| {
+                let page_number = u32::try_from(index + 1).expect("page number fits in u32");
+                WalFrameRef {
+                    page_number,
+                    page_data: page,
+                    db_size_if_commit: if index == last_page_index {
+                        page_number
+                    } else {
+                        0
+                    },
+                }
+            })
+            .collect::<Vec<_>>();
+        let mut prepared = adapter
+            .prepare_append_frames(&frames)
+            .expect("prepare append")
+            .expect("prepared batch");
+        adapter
+            .append_prepared_frames(&cx, &mut prepared)
+            .expect("append prepared");
+
+        assert_eq!(
+            adapter.published_snapshot.last_commit_frame,
+            Some(last_page_index),
+            "large prepared commit append should publish the visible commit horizon"
+        );
+        assert_eq!(
+            adapter.published_snapshot.commit_count, 1,
+            "large prepared commit append should track the visible WAL commit count"
+        );
+        assert_eq!(
+            adapter.published_snapshot.page_index.len(),
+            DIRECT_PREPARED_PUBLICATION_FRAME_THRESHOLD,
+            "large prepared commit append should publish all committed pages"
+        );
+        assert_eq!(adapter.published_snapshot.page_index.get(&1), Some(&0));
+        assert_eq!(
+            adapter.published_snapshot.page_index.get(
+                &u32::try_from(DIRECT_PREPARED_PUBLICATION_FRAME_THRESHOLD)
+                    .expect("threshold fits in u32")
+            ),
+            Some(&last_page_index)
+        );
+        assert!(
+            adapter.pending_publication_frames.is_empty(),
+            "large direct publication should not leave pending frame entries"
+        );
+    }
