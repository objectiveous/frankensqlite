+            }
+            PreparedDirectSimpleInsertExpr::ConcatChain(_)
+            | PreparedDirectSimpleInsertExpr::BinaryOp { .. }
+            | PreparedDirectSimpleInsertExpr::UnaryOp { .. }
+            | PreparedDirectSimpleInsertExpr::Cast { .. }
+            | PreparedDirectSimpleInsertExpr::IsNull { .. } => None,
+        }
