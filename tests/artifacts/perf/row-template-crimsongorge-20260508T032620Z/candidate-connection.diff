+    fn try_serialize_prepared_direct_insert_record_template<'a>(
+        table_name: &str,
+        template: &'a PreparedDirectInsertRecordTemplate,
+        params: Option<&'a [SqliteValue]>,
+        record_scratch: &mut Vec<u8>,
+        text_scratch: &mut String,
+    ) -> Result<PreparedDirectInsertRecordBuild> {
+        text_scratch.clear();
+        let mut param_one_integer_buffer = itoa::Buffer::new();
+        let cached_param_one_integer_text = match params.and_then(|values| values.first()) {
+            Some(SqliteValue::Integer(value)) => Some(param_one_integer_buffer.format(*value)),
+            _ => None,
+        };
+        let mut explicit_rowid = None;
+        let mut cells: SmallVec<[PreparedDirectInsertRecordCell<'a>; 16]> =
+            SmallVec::with_capacity(template.columns.len());
+        let mut header_content_size = 0usize;
+        let mut body_size = 0usize;
+        for column in &template.columns {
+            if column.is_rowid_alias {
+                let Some(raw_value) = Self::try_eval_prepared_direct_insert_record_template_op(
+                    &column.op,
+                    params,
+                    text_scratch,
+                    cached_param_one_integer_text,
+                )?
+                else {
+                    return Ok(PreparedDirectInsertRecordBuild::Fallback);
+                };
+                explicit_rowid = Self::coerce_prepared_direct_insert_record_rowid_value(
+                    raw_value,
+                    text_scratch.as_str(),
+                );
+                let cell =
+                    Self::prepared_direct_insert_record_cell(PreparedDirectInsertRecordValue::Null);
+                header_content_size += varint_len(cell.serial_type);
+                body_size += cell.payload_len;
+                cells.push(cell);
+                continue;
+            }
+
+            let Some(raw_value) = Self::try_eval_prepared_direct_insert_record_template_op(
+                &column.op,
+                params,
+                text_scratch,
+                cached_param_one_integer_text,
+            )?
+            else {
+                return Ok(PreparedDirectInsertRecordBuild::Fallback);
+            };
+            if column.notnull && raw_value.is_null() {
+                return Err(FrankenError::NotNullViolation {
+                    column: format!("{table_name}.{}", column.name),
+                });
+            }
+            let Some(value) = Self::apply_prepared_direct_insert_record_affinity(
+                raw_value,
+                column.affinity,
+                text_scratch,
+            ) else {
+                return Ok(PreparedDirectInsertRecordBuild::Fallback);
+            };
+            let cell = Self::prepared_direct_insert_record_cell(value);
+            header_content_size += varint_len(cell.serial_type);
+            body_size += cell.payload_len;
+            cells.push(cell);
+        }
+
+        Self::serialize_prepared_direct_insert_record_cells_into(
+            cells.as_slice(),
+            header_content_size,
+            body_size,
+            text_scratch.as_str(),
+            record_scratch,
+        );
+        Ok(PreparedDirectInsertRecordBuild::Serialized { explicit_rowid })
+    }
