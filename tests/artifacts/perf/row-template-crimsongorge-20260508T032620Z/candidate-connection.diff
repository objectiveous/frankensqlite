+    fn coerce_prepared_direct_insert_record_rowid_value(
+        value: PreparedDirectInsertRecordValue<'_>,
+        text_scratch: &str,
+    ) -> Option<i64> {
+        match value {
+            PreparedDirectInsertRecordValue::Null => None,
+            PreparedDirectInsertRecordValue::Integer(value) => Some(value),
+            PreparedDirectInsertRecordValue::Float(value) => {
+                Some(SqliteValue::Float(value).to_integer())
+            }
+            PreparedDirectInsertRecordValue::TextBorrowed(text) => {
+                let text = std::str::from_utf8(text).unwrap_or_default();
+                Some(SqliteValue::Text(fsqlite_types::SmallText::new(text)).to_integer())
+            }
+            PreparedDirectInsertRecordValue::TextScratch { start, len } => Some(
+                SqliteValue::Text(fsqlite_types::SmallText::new(
+                    &text_scratch[start..start + len],
+                ))
+                .to_integer(),
+            ),
+            PreparedDirectInsertRecordValue::BlobBorrowed(blob) => {
+                Some(SqliteValue::Blob(Arc::from(blob)).to_integer())
+            }
+        }
+    }
