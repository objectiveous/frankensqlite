+    fn try_append_prepared_direct_insert_record_template_concat_to_scratch(
+        segments: &[PreparedDirectInsertRecordTemplateConcatSegment],
+        params: Option<&[SqliteValue]>,
+        text_scratch: &mut String,
+        cached_param_one_integer_text: Option<&str>,
+    ) -> Result<Option<Range<usize>>> {
+        let start = text_scratch.len();
+        let mut saw_null = false;
+        for segment in segments {
+            match segment {
+                PreparedDirectInsertRecordTemplateConcatSegment::NullLiteral => {
+                    saw_null = true;
+                }
+                PreparedDirectInsertRecordTemplateConcatSegment::TextLiteral(value) => {
+                    if !saw_null {
+                        text_scratch.push_str(value);
+                    }
+                }
+                PreparedDirectInsertRecordTemplateConcatSegment::Literal(value) => {
+                    if value.is_null() {
+                        saw_null = true;
+                    } else if !saw_null {
+                        Self::append_prepared_direct_simple_insert_text(text_scratch, value);
+                    }
+                }
+                PreparedDirectInsertRecordTemplateConcatSegment::Placeholder(one_based) => {
+                    if *one_based == 1
+                        && let Some(cached_text) = cached_param_one_integer_text
+                    {
+                        text_scratch.push_str(cached_text);
+                        continue;
+                    }
+                    let value = Self::prepared_direct_simple_insert_param(params, *one_based)?;
+                    if value.is_null() {
+                        saw_null = true;
+                    } else if !saw_null {
+                        Self::append_prepared_direct_simple_insert_text(text_scratch, value);
+                    }
+                }
+                PreparedDirectInsertRecordTemplateConcatSegment::NumericBinary(numeric) => {
+                    let Some(value) =
+                        Self::eval_prepared_direct_insert_record_template_numeric_binary(
+                            numeric,
+                            params,
+                            text_scratch,
+                        )?
+                    else {
+                        text_scratch.truncate(start);
+                        return Ok(None);
+                    };
+                    match value {
+                        PreparedDirectInsertRecordValue::Null => {
+                            saw_null = true;
+                        }
+                        PreparedDirectInsertRecordValue::Integer(value) if !saw_null => {
+                            let mut buffer = itoa::Buffer::new();
+                            text_scratch.push_str(buffer.format(value));
+                        }
+                        PreparedDirectInsertRecordValue::Float(value) if !saw_null => {
+                            text_scratch.push_str(&format_sqlite_float(value));
+                        }
+                        _ => {
+                            text_scratch.truncate(start);
+                            return Ok(None);
+                        }
+                    }
+                }
+            }
+        }
+        if saw_null {
+            text_scratch.truncate(start);
+            Ok(None)
+        } else {
+            Ok(Some(start..text_scratch.len()))
+        }
+    }
