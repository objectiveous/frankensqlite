+    #[test]
+    fn test_stmt_microbatch_coalesces_repeated_update_delete() {
+        let conn = Connection::open(":memory:").unwrap();
+        conn.execute(
+            "CREATE TABLE t(
+                id INTEGER PRIMARY KEY,
+                name TEXT NOT NULL,
+                value REAL NOT NULL
+            );",
+        )
+        .unwrap();
+        conn.execute("BEGIN;").unwrap();
+        let ins = conn
+            .prepare("INSERT INTO t VALUES (?1, ('user_' || ?1), (?1 * 0.25))")
+            .unwrap();
+        for i in 0..20_i64 {
+            ins.execute_with_params(&[SqliteValue::Integer(i)]).unwrap();
+        }
+        conn.execute("COMMIT;").unwrap();
+
+        let (hits_before, renewals_before) = conn.stmt_microbatch_counters();
+
+        conn.execute("BEGIN;").unwrap();
+        let upd = conn
+            .prepare("UPDATE t SET value = ?2 WHERE id = ?1")
+            .unwrap();
+        for i in 0..10_i64 {
+            upd.execute_with_params(&[SqliteValue::Integer(i), SqliteValue::Float(99.0)])
+                .unwrap();
+        }
+        let del = conn.prepare("DELETE FROM t WHERE id = ?1").unwrap();
+        for i in 10..20_i64 {
+            del.execute_with_params(&[SqliteValue::Integer(i)]).unwrap();
+        }
+        conn.execute("COMMIT;").unwrap();
+
+        let (hits_after, renewals_after) = conn.stmt_microbatch_counters();
+        assert!(
+            hits_after >= hits_before + 18,
+            "expected repeated UPDATE and DELETE calls to carry after the first renewal for each statement: before={hits_before} after={hits_after}"
+        );
+        assert!(
+            renewals_after >= renewals_before + 2,
+            "expected one renewal for UPDATE and one for DELETE: before={renewals_before} after={renewals_after}"
+        );
+
+        let rows = conn.query("SELECT COUNT(*) FROM t;").unwrap();
+        assert_eq!(row_values(&rows[0]), vec![SqliteValue::Integer(10)]);
+    }
