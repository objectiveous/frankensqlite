+    /// immediately after pager construction, so the sharded map is only a
+    /// fallback tier. Keep that fallback small without changing the default
+    /// file-backed/concurrent cache fanout.
+    pub fn with_max_buffers_for_initial_pages_single_connection(
+        page_size: PageSize,
+        max_buffers: usize,
+        initial_pages: u32,
+    ) -> Self {
+        Self::with_max_buffers_for_initial_pages_and_shards(
+            page_size,
+            max_buffers,
+            initial_pages,
+            MIN_PAGE_CACHE_SHARDS,
+        )
+    }
